PORT=3000
NODE_ENV=development

# Render public URL, for example https://your-service.onrender.com
PUBLIC_BASE_URL=http://localhost:3000

# Google Drive OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=

# Required before issuing upload authorization. Use a long private phrase.
UPLOAD_PASSWORD=change-this-upload-password

# Limits and expiry
MAX_FILE_SIZE_BYTES=1073741824
UPLOAD_SESSION_EXPIRES_SECONDS=900
